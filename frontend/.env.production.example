# Copy to .env.production and set values before: npm run build
# API base URL only — no /api suffix (the app adds /api/... paths).

REACT_APP_API_URL=https://YOUR-ENVIRONMENT.REGION.elasticbeanstalk.com
REACT_APP_GOOGLE_CLIENT_ID=your_id.apps.googleusercontent.com
REACT_APP_CLOUDINARY_CLOUD_NAME=your_cloud_name
REACT_APP_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
